{
  "name": "desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite --port 5201\" \"wait-on http://localhost:5201 && env -u ELECTRON_RUN_AS_NODE NODE_ENV=development electron .\"",
    "build": "vue-tsc -b && vite build",
    "dist": "vue-tsc -b && vite build && electron-builder",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/vue-3": "^3.26.1",
    "@vueuse/core": "^14.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "ali-oss": "^6.23.0",
    "axios": "^1.16.1",
    "element-plus": "^2.14.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.4",
    "node-pty": "^1.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.6.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.agentworkbench.desktop",
    "productName": "Agent Workbench",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "release"
    }
  }
}
