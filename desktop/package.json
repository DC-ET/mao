{
  "name": "desktop",
  "private": true,
  "version": "0.0.14",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite --port 5201\" \"wait-on http://localhost:5201 && env -u ELECTRON_RUN_AS_NODE NODE_ENV=development electron .\"",
    "build": "vue-tsc -b && vite build",
    "dist": "electron-builder",
    "preview": "vite preview",
    "postinstall": "node ./node_modules/@electron/rebuild/lib/cli.js -f -w node-pty"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.8.9",
    "minimatch": "^10.0.1",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/vue-3": "^3.26.1",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.12.3",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ali-oss": "^6.23.0",
    "axios": "^1.16.1",
    "concurrently": "^9.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "element-plus": "^2.14.0",
    "marked": "^18.0.4",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue": "^3.5.34",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "cn.etarch.mao.desktop",
    "productName": "Mao",
    "icon": "public/AppIcon.icns",
    "publish": [
      {
        "provider": "generic",
        "url": "https://mao.etarch.cn/api/uploads/releases/"
      }
    ],
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**/*"
    ],
    "electronLanguages": [
      "en",
      "en-US",
      "zh_CN",
      "zh_TW"
    ],
    "mac": {
      "icon": "public/AppIcon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "release"
    }
  }
}
